# Auth service environment

AUTH_ENV=dev                        # dev | prod
AUTH_APP_NAME=auth
AUTH_DATABASE_URL=sqlite+aiosqlite:///./auth.db
# AUTH_DATABASE_URL=postgresql+asyncpg://user:pass@host/auth

# JWT — secret loaded with this priority:
#   AUTH_JWT_SECRET (raw)  >  AUTH_JWT_SECRET_FILE (path)  >  auto-generate at <state_dir>/jwt_secret
AUTH_JWT_SECRET=
AUTH_JWT_SECRET_FILE=
AUTH_STATE_DIR=./.state
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_KEY_ID=v1
AUTH_ACCESS_TOKEN_MINUTES=60
AUTH_REFRESH_TOKEN_DAYS=7

AUTH_OTP_TTL_MINUTES=15
AUTH_OTP_LENGTH=6

AUTH_NOTIFY_BASE_URL=http://10.10.10.119:8000
AUTH_NOTIFY_CLI=notify
AUTH_NOTIFY_TIMEOUT_SECONDS=10.0

# Rate limits (requests / minute)
# IP-based (slowapi)
AUTH_RATELIMIT_OTP=5/minute
AUTH_RATELIMIT_LOGIN=10/minute
AUTH_RATELIMIT_OAUTH=30/minute
# Identity-based (por external_id ou phone) — in-memory, per-process
AUTH_RATELIMIT_OTP_ID=3/minute
AUTH_RATELIMIT_LOGIN_ID=5/minute

AUTH_LOG_LEVEL=INFO
AUTH_HEALTHCHECK_NOTIFY_TIMEOUT=2.0
AUTH_NOTIFY_SUBPROCESS_TIMEOUT=15.0
